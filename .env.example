# Thala Environment Variables
# Copy this file to `.env` and fill in your local values.
# Never commit `.env` or any real secrets.

# ── Core Runtime ──────────────────────────────────────────────
# Provider key resolution at runtime:
# 1) explicit key passed from config/CLI
# 2) provider-specific env var (OPENROUTER_API_KEY, OPENAI_API_KEY, ...)
# 3) generic fallback env vars below

# Generic fallback API key (used when provider-specific key is absent)
API_KEY=your-api-key-here
# THALA_API_KEY=your-api-key-here

# Default provider/model (can be overridden by CLI flags)
PROVIDER=opencode
# THALA_PROVIDER=openrouter
# THALA_MODEL=anthropic/claude-sonnet-4-6
# THALA_TEMPERATURE=0.7

# Workspace directory override
# THALA_WORKSPACE=/path/to/workspace

# Reasoning mode (enables extended thinking for supported models)
# THALA_REASONING_ENABLED=false
# REASONING_ENABLED=false

# ── Provider-Specific API Keys ────────────────────────────────
# OpenRouter
# OPENROUTER_API_KEY=sk-or-v1-...

# Anthropic
# ANTHROPIC_OAUTH_TOKEN=...
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI / Gemini
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...
# GOOGLE_API_KEY=...

# Other supported providers
# VENICE_API_KEY=...
# GROQ_API_KEY=...
# MISTRAL_API_KEY=...
# DEEPSEEK_API_KEY=...
# XAI_API_KEY=...
# TOGETHER_API_KEY=...
# FIREWORKS_API_KEY=...
# PERPLEXITY_API_KEY=...
# COHERE_API_KEY=...
# MOONSHOT_API_KEY=...
# GLM_API_KEY=...
# MINIMAX_OAUTH_TOKEN=...
# MINIMAX_API_KEY=...
# MINIMAX_OAUTH_REFRESH_TOKEN=...
# MINIMAX_OAUTH_REGION=global   # optional: global|cn
# QIANFAN_API_KEY=...
# DASHSCOPE_API_KEY=...
# ZAI_API_KEY=...
# SYNTHETIC_API_KEY=...
# OPENCODE_API_KEY=...
# OPENCODE_GO_API_KEY=...
# VERCEL_API_KEY=...
# CLOUDFLARE_API_KEY=...

# ── Gateway ──────────────────────────────────────────────────
# THALA_GATEWAY_PORT=3000
# THALA_GATEWAY_HOST=127.0.0.1
# THALA_ALLOW_PUBLIC_BIND=false

# ── Storage ─────────────────────────────────────────────────
# Backend override for persistent storage (default: sqlite)
# THALA_STORAGE_PROVIDER=sqlite
# THALA_STORAGE_DB_URL=postgres://localhost/thala
# THALA_STORAGE_CONNECT_TIMEOUT_SECS=5

# ── Proxy ──────────────────────────────────────────────────
# Forward provider/service traffic through an HTTP(S) proxy.
# THALA_PROXY_ENABLED=false
# THALA_HTTP_PROXY=http://proxy.example.com:8080
# THALA_HTTPS_PROXY=http://proxy.example.com:8080
# THALA_ALL_PROXY=socks5://proxy.example.com:1080
# THALA_NO_PROXY=localhost,127.0.0.1
# THALA_PROXY_SCOPE=thala          # environment|thala|services
# THALA_PROXY_SERVICES=openai,anthropic

# ── Optional Integrations ────────────────────────────────────
# Pushover notifications (`pushover` tool)
# PUSHOVER_TOKEN=your-pushover-app-token
# PUSHOVER_USER_KEY=your-pushover-user-key

# ── Docker Compose ───────────────────────────────────────────
# Host port mapping (used by docker-compose.yml)
# HOST_PORT=3000

# ── Z.AI GLM Coding Plan ───────────────────────────────────────
# Z.AI provides GLM models through OpenAI-compatible endpoints.
# API key format: id.secret (e.g., abc123.xyz789)
#
# Usage:
#   thala onboard --provider zai --api-key YOUR_ZAI_API_KEY
#
# Or set the environment variable:
# ZAI_API_KEY=your-id.secret
#
# Common models: glm-5, glm-4.7, glm-4-plus, glm-4-flash
# See docs/zai-glm-setup.md for detailed configuration.

# ── Web Search ────────────────────────────────────────────────
# Web search tool for finding information on the internet.
# Enabled by default with DuckDuckGo (free, no API key required).
#
# WEB_SEARCH_ENABLED=true
# WEB_SEARCH_PROVIDER=duckduckgo
# WEB_SEARCH_MAX_RESULTS=5
# WEB_SEARCH_TIMEOUT_SECS=15
#
# Optional: Brave Search (requires API key from https://brave.com/search/api)
# WEB_SEARCH_PROVIDER=brave
# BRAVE_API_KEY=your-brave-search-api-key

# ── Orchestrator ──────────────────────────────────────────────
# Required when running Thala as a development-task orchestrator.
# See THALA_SETUP.md for full setup instructions.
#
# NOTE: When running as a systemd daemon these credentials should be set
# via Environment= directives in the service unit file, not in .env.
# The .env file is only loaded in local/dev runs. The systemd unit file
# takes precedence; see THALA_SETUP.md § "Required environment variables".

# Notion task tracker (required for Notion backend)
# NOTION_API_TOKEN=ntn_xxxxxxxxxxxx

# Discord webhook for alerts and escalation (channel: #thala-alerts)
# DISCORD_ALERTS_WEBHOOK=https://discord.com/api/webhooks/...

# Telegram bot for stall-timeout and critical-review escalation
# TELEGRAM_BOT_TOKEN=...
# TELEGRAM_ESCALATION_CHAT_IDS=123456

# GCP project and region (required by gcloud_* orchestrator tools)
# GCP_PROJECT=your-gcp-project-id
# GCP_REGION=us-central1

# Remote worker backends (Modal / Cloudflare) — only needed for non-local backends
# THALA_GITHUB_TOKEN=ghp_xxxxxxxxxxxx        # GitHub PAT for branch push/PR creation
# THALA_CALLBACK_SECRET=<random 32-byte hex> # Shared secret for worker completion callbacks
# OPENCODE_API_KEY=sk-xxxx                 # OpenCode Zen key (opencode.ai/settings)

# Cloudflare Containers backend
# CF_ACCOUNT_ID=your-cloudflare-account-id
# CF_API_TOKEN=your-cloudflare-api-token
