{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "types": [
      "@cloudflare/workers-types",
      "@cloudflare/vitest-pool-workers",
      "node",
      "vitest"
    ]
  },
  "include": ["src/**/*.ts", "test/**/*.ts", "vitest.config.ts"]
}
